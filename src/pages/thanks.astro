---
import CallToAction from "../components/ui/CallToAction.astro";
import SuccessCard from "../components/ui/SuccessCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

// No-JS fallback target for the booking form's native POST (see Booking.astro).
---

<BaseLayout title="Thank you — Your Family Paediatrician" noindex>
  <section class="section">
    <div class="wrapper">
      <div class="card-holder">
        <SuccessCard headingLevel="h1">
          <div class="cta-row">
            <CallToAction href="/" size="small">
              Back to the homepage
            </CallToAction>
          </div>
        </SuccessCard>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .card-holder {
    max-width: 34rem;
    margin: 0 auto;
  }

  .cta-row {
    margin-top: 1.5rem;
  }
</style>
