---
import CallToAction from "../components/ui/CallToAction.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="404 Error — this page was not found">
  <section class="section">
    <div class="wrapper not-found">
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p class="lede">
        The page you're looking for doesn't exist — everything now lives on the
        homepage.
      </p>
      <CallToAction href="/">Back to the homepage</CallToAction>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
  }

  .lede {
    max-width: 34em;
    color: var(--text-muted);
  }
</style>
