---
type Props = {
  size?: number;
};

const { size = 36 } = Astro.props;

// favicon.svg has a 174.4 × 121.1 viewBox, so scale width to keep its ratio
const logoWidth = Math.round(size * (174.40541 / 121.08108));
---

<a href="/#home" class="brand">
  <img
    src="/favicon.svg"
    alt=""
    width={logoWidth}
    height={size}
    aria-hidden="true"
  />
  <span class="wordmark">Your Family Paediatrician</span>
</a>

<style>
  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--text);
  }

  .wordmark {
    font-family: var(--font-brand);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
  }
</style>
