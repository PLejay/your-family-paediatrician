---
import { PRACTICE_EMAIL as email } from "../constants";
import SectionHeader from "./SectionHeader.astro";
import SuccessCard from "./ui/SuccessCard.astro";

const contactDetails = [
  { label: "Email", value: email, href: `mailto:${email}` },
  { label: "In clinic", value: "Central Health London · W1" },
  { label: "Home visits", value: "Available across London" },
  {
    label: "Response time",
    value: "I usually reply within 1–2 working days",
  },
];

const topics = [
  "Private consultation",
  "Home visit",
  "Workshop enquiry",
  "Fees & packages",
  "Something else",
];
---

<section id="book" class="section alt">
  <div class="wrapper">
    <div class="layout">
      <div class="info">
        <SectionHeader
          eyebrow="Book a consultation"
          title="Let's find a time that works for you"
          intro="Share a few details and I'll be in touch to arrange your appointment — in clinic, by video, or at home. For anything urgent, please call 999 or NHS 111."
        />
        <ul class="contact-list">
          {
            contactDetails.map(({ label, value, href }) => (
              <li>
                <span class="dot" aria-hidden="true" />
                <div>
                  <div class="contact-label">{label}</div>
                  {href ? <a href={href}>{value}</a> : <p>{value}</p>}
                </div>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="form-column">
        <!--
          Handled by Netlify Forms (see agent-notes/08-booking-form-netlify.md).
          The script below submits via fetch and swaps in the success card;
          without JS the native POST is intercepted by Netlify and lands on /thanks/.
        -->
        <form
          name="booking"
          method="POST"
          action="/thanks/"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="enquiry-form"
        >
          <input type="hidden" name="form-name" value="booking" />
          <p class="trap" aria-hidden="true">
            <label>
              Don't fill this out if you're human: <input name="bot-field" />
            </label>
          </p>
          <div class="field-row">
            <label>
              <span class="field-label">Your name</span>
              <input name="name" type="text" autocomplete="name" required />
            </label>
            <label>
              <span class="field-label">Email</span>
              <input name="email" type="email" autocomplete="email" required />
            </label>
          </div>
          <div class="field-row">
            <label>
              <span class="field-label">
                Phone <span class="optional">(optional)</span>
              </span>
              <input name="phone" type="tel" autocomplete="tel" />
            </label>
            <label>
              <span class="field-label">Child's age</span>
              <input name="age" type="text" placeholder="e.g. 4 months" />
            </label>
          </div>
          <label>
            <span class="field-label">What would you like help with?</span>
            <select name="topic">
              {topics.map((topic) => <option>{topic}</option>)}
            </select>
          </label>
          <label>
            <span class="field-label">How can I help?</span>
            <textarea name="message" rows="4"></textarea>
          </label>
          <button type="submit" class="cta primary">Send request</button>
          <p class="form-error" role="alert" hidden>
            Sorry — something went wrong sending your request. Please try
            again, or email <a href={`mailto:${email}`}>{email}</a> directly.
          </p>
          <p class="privacy-note">
            Your details are only used to respond to your enquiry — see the
            <a href="/privacy/">privacy policy</a>.
          </p>
        </form>
        <SuccessCard hidden focusable />
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>(".enquiry-form");
  const successCard = document.querySelector<HTMLElement>(".success-card");
  const errorNote = document.querySelector<HTMLElement>(".form-error");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const button = form.querySelector<HTMLButtonElement>(
      "button[type='submit']",
    );
    if (button) button.disabled = true;
    if (errorNote) errorNote.hidden = true;
    const body = new URLSearchParams();
    new FormData(form).forEach((value, key) => body.append(key, value.toString()));
    try {
      const response = await fetch(window.location.pathname, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: body.toString(),
      });
      // A redirected POST means a redirect rule swallowed the submission
      // (the browser re-issues it as a body-less GET that returns 200).
      if (!response.ok || response.redirected) {
        throw new Error(`Form POST failed: ${response.status}`);
      }
      form.hidden = true;
      if (successCard) {
        successCard.hidden = false;
        successCard.focus();
      }
    } catch {
      if (errorNote) errorNote.hidden = false;
      if (button) button.disabled = false;
    }
  });
</script>

<style>
  .layout {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(2.25rem, 5vw, 4rem);
  }

  .info {
    flex: 1 1 360px;
    min-width: 280px;
  }

  .form-column {
    flex: 1 1 440px;
    min-width: 300px;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.9375rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.8125rem;
  }

  .dot {
    flex: none;
    width: 9px;
    height: 9px;
    margin-top: 6px;
    border-radius: 50%;
    background-color: var(--accent-regular);
  }

  .contact-label {
    font-size: 13.5px;
    font-weight: 600;
    color: #3a4a46;
  }

  .contact-list p {
    font-size: 15.5px;
    color: var(--text-muted);
  }

  .contact-list a {
    font-size: 15.5px;
    font-weight: 600;
    color: var(--accent-deep);
    text-decoration: none;
  }

  .enquiry-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.5rem, 3vw, 2.125rem);
    background-color: var(--card-tint);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
  }

  /* Scoped display:flex would otherwise beat the UA's non-!important
     [hidden] rule in browsers without the until-found update (iOS Safari). */
  .enquiry-form[hidden] {
    display: none;
  }

  .trap {
    display: none;
  }

  label {
    display: block;
  }

  .field-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .field-row label {
    flex: 1 1 180px;
  }

  .field-label {
    font-size: 13.5px;
    font-weight: 600;
    color: #3a4a46;
  }

  .optional {
    font-weight: 400;
    color: #8a9893;
  }

  input,
  select,
  textarea {
    box-sizing: border-box;
    width: 100%;
    margin-top: 6px;
    padding: 12px 14px;
    border: 1px solid #d8e0dd;
    border-radius: 12px;
    background-color: var(--gray-999);
    font-family: inherit;
    font-size: 0.9375rem;
    color: var(--text);
  }

  select {
    appearance: none;
    cursor: pointer;
  }

  textarea {
    resize: vertical;
  }

  /* The pill styling itself comes from the global .cta.primary classes. */
  button.cta {
    width: 100%;
    margin-top: 0.25rem;
    border: none;
  }

  button.cta:disabled {
    cursor: default;
    opacity: 0.7;
  }

  .form-error {
    font-size: 0.9375rem;
    color: var(--red-200);
    text-align: center;
  }

  .privacy-note {
    font-size: 12.5px;
    color: #8a9893;
    text-align: center;
  }

  .privacy-note a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }
</style>
