---
import { Image } from "astro:assets";
import portrait from "../assets/portrait-bricks-cropped.jpg";
import CallToAction from "./ui/CallToAction.astro";
import Stars from "./ui/Stars.astro";

const doctifyUrl = "https://www.doctify.com/uk/specialist/shiri-lejay";
---

<section id="home" class="hero">
  <div class="glow" aria-hidden="true"></div>
  <div class="wrapper layout">
    <div class="intro">
      <p class="eyebrow">Hello, I'm Dr Shiri Lejay</p>
      <h1>Your family paediatrician,<br /> for calm and confident parenting.</h1>
      <p class="credentials">
        Consultant Paediatrician · MB · MRCPCH · DTM&amp;H · LFHom (Med) ·
        PGCert (Med Ed)
      </p>
      <p class="lede">
        As a paediatrician and a mother, I understand how overwhelming it can
        feel to make sense of your child's health — especially with so much
        conflicting information. I'm here to help you cut through the noise
        with clear, practical advice, so you can feel calm and confident about
        what to do next.
      </p>
      <div class="cta-row">
        <CallToAction href="#book">Book a consultation</CallToAction>
        <CallToAction variant="outline">Get in touch</CallToAction>
      </div>
      <div class="trust-row">
        <a class="trust-item" href={doctifyUrl} target="_blank" rel="noopener">
          <Stars label="Rated 4.97 out of 5 on Doctify" /> 4.97 / 5 on Doctify
        </a>
        <span class="dot" aria-hidden="true"></span>
        <span>Private appointments at Central Health London</span>
        <span class="dot" aria-hidden="true"></span>
        <span>Home visits available</span>
      </div>
    </div>
    <div class="portrait">
      <Image
        src={portrait}
        alt="Dr Shiri Lejay smiling in front of an exposed-brick wall"
        widths={[400, 640, 800, 1200]}
        sizes="(max-width: 50em) 100vw, 40vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3rem, 7vw, 5.75rem) clamp(3.5rem, 8vw, 6.5rem);
  }

  .glow {
    position: absolute;
    top: -120px;
    right: -160px;
    width: 520px;
    height: 520px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 30%,
      var(--aqua-tint),
      transparent 70%
    );
    pointer-events: none;
  }

  .layout {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(2.25rem, 5vw, 4.5rem);
  }

  .intro {
    flex: 1 1 500px;
    min-width: 300px;
  }

  .eyebrow {
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2rem, 4.2vw, 2.625rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .credentials {
    font-size: 0.8438rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text-faint);
    margin-bottom: 1.375rem;
  }

  .lede {
    max-width: 30em;
    font-size: clamp(1rem, 1.4vw, 1.1563rem);
    line-height: 1.72;
    color: var(--text-muted);
    margin-bottom: 1.75rem;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 1.625rem;
  }

  .trust-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.125rem;
    font-size: 0.9063rem;
    font-weight: 500;
    color: #5b6a66;
  }

  .trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    color: inherit;
    text-decoration: none;
  }

  a.trust-item:hover,
  a.trust-item:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: #bcc7c3;
  }

  .portrait {
    flex: 1 1 320px;
    min-width: 260px;
  }

  .portrait img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius);
  }
</style>
