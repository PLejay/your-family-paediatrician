---
import { render, type CollectionEntry } from "astro:content";

type Props = {
  service: CollectionEntry<"services">;
};

const { service } = Astro.props;
const { title, icon, cta_label, cta_href, cta_topic } = service.data;
const external = cta_href.startsWith("http");
const { Content } = await render(service);
---

<article class="service-card">
  <div class="icon-tile" aria-hidden="true"><span class={icon}></span></div>
  <h3>{title}</h3>
  <div class="description">
    <Content />
  </div>
  <a
    href={cta_href}
    target={external ? "_blank" : undefined}
    rel={external ? "noopener" : undefined}
    data-book-topic={cta_topic}
    class="card-link"
  >
    {cta_label} →
  </a>
</article>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    padding: clamp(1.5rem, 3vw, 2rem);
    background-color: var(--gray-999);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    box-shadow: 0 1px 2px rgb(31 58 52 / 4%);
  }

  .icon-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    margin-bottom: 1.125rem;
    border-radius: 14px;
    background-color: var(--aqua-tint);
  }

  .icon-tile span {
    width: 16px;
    height: 16px;
    background-color: var(--accent-regular);
  }

  .icon-tile .circle {
    border-radius: 50%;
  }

  .icon-tile .square {
    border-radius: 4px;
  }

  .icon-tile .diamond {
    clip-path: polygon(50% 0, 100% 50%, 50% 100%, 0 50%);
  }

  h3 {
    font-size: 1.3125rem;
    margin-bottom: 0.625rem;
  }

  .description {
    flex: 1;
    margin-bottom: 1.125rem;
  }

  .description :global(p) {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--text-muted);
  }

  .card-link {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--accent-deep);
    text-decoration: none;
  }
</style>
