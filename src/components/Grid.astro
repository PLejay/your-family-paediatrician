---
type Props = {
  minCol?: string;
};

const { minCol = "250px" } = Astro.props;
---

<ul class="grid" style={`--min-col: ${minCol}`}>
  <slot />
</ul>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(var(--min-col), 100%), 1fr));
    gap: 1.25rem;
    width: 100%;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Stretch each card to fill its cell so rows stay equal height. */
  .grid > :global(li) {
    display: grid;
  }
</style>
