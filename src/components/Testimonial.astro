---
import { render, type CollectionEntry } from "astro:content";
import Stars from "./ui/Stars.astro";

type Props = {
  testimonial: CollectionEntry<"testimonials">;
};

const { Content } = await render(Astro.props.testimonial);
---

<figure class="testimonial">
  <Stars />
  <blockquote>
    <Content />
  </blockquote>
</figure>

<style>
  .testimonial {
    margin: 0;
    padding: 1.75rem;
    background-color: var(--card-tint);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
  }

  blockquote {
    margin: 0.75rem 0 0;
    font-style: italic;
    font-size: 1.1875rem;
    line-height: 1.5;
    color: #2f3f3b;
  }

  blockquote :global(p) {
    margin: 0;
  }
</style>
