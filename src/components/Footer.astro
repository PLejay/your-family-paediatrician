---
import { PRACTICE_EMAIL } from "../constants";
import Brand from "./Brand.astro";

const currentYear = new Date().getFullYear();

const links = [
  {
    label: PRACTICE_EMAIL,
    href: `mailto:${PRACTICE_EMAIL}`,
    accent: true,
  },
  {
    label: "Instagram",
    href: "https://www.instagram.com/your_family_paediatrician/",
  },
  { label: "Doctify", href: "https://www.doctify.com/uk/specialist/shiri-lejay" },
  {
    label: "Central Health London",
    href: "https://www.centralhealthlondon.com/practitioners/dr-shiri-lejay",
  },
];
---

<footer>
  <div class="wrapper">
    <div class="top">
      <Brand size={32} />
      <nav class="links" aria-label="Contact and profiles">
        {
          links.map(({ label, href, accent }) => (
            <a
              href={href}
              class:list={{ accent }}
              target={href.startsWith("http") ? "_blank" : undefined}
              rel={href.startsWith("http") ? "noopener" : undefined}
            >
              {label}
            </a>
          ))
        }
      </nav>
    </div>
    <p class="disclaimer">
      This website is for general information and does not replace urgent or
      emergency medical care. In an emergency, call 999 or NHS 111.
    </p>
    <div class="bottom">
      <span>
        Built by <a href="https://github.com/PLejay/your-family-paediatrician">
          Pierre Lejay
        </a>
      </span>
      <span><a href="/privacy/">Privacy policy</a></span>
      <span>© {currentYear} Your Family Paediatrician</span>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: auto;
    padding: 2.75rem 0 2.25rem;
    background-color: var(--gray-999);
    border-top: 1px solid var(--border-soft);
  }

  .top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.375rem;
    font-size: 0.9063rem;
    font-weight: 600;
  }

  .links a {
    color: #5b6a66;
    text-decoration: none;
  }

  .links a.accent {
    color: var(--accent-deep);
  }

  .bottom a {
    color: inherit;
  }

  .links a:hover,
  .links a:focus-visible,
  .bottom a:hover,
  .bottom a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  .disclaimer {
    max-width: 60em;
    margin-bottom: 0.625rem;
    font-size: 0.7813rem;
    line-height: 1.6;
    color: #8a9893;
  }

  .bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 1.125rem;
    font-size: 0.7813rem;
    color: #9aa6a2;
  }
</style>
