---
import CallToAction from "./ui/CallToAction.astro";

const bookingUrl =
  "https://www.centralhealthlondon.com/practitioners/dr-shiri-lejay";

// Root-absolute fragments (not bare `#help`) so the links still resolve from
// non-index routes like 404.astro, which also render this nav via BaseLayout.
// Section ids live in src/pages/index.astro.
const navLinks: { label: string; href: string }[] = [
  { label: "How I help", href: "/#help" },
  { label: "Services", href: "/#services" },
  { label: "Workshops", href: "/#workshops" },
  { label: "About", href: "/#about" },
  { label: "Reviews", href: "/#reviews" },
];
---

<header class="site-header">
  <div class="wrapper nav-bar">
    <a href="/#home" class="brand">
      <svg width="36" height="36" viewBox="0 0 40 40" aria-hidden="true">
        <circle cx="15.5" cy="22" r="11" fill="var(--accent-regular)"></circle>
        <circle cx="26" cy="16.5" r="7.5" fill="var(--accent-light)"></circle>
        <circle cx="26" cy="16.5" r="2.6" fill="#fff"></circle>
      </svg>
      <span class="wordmark">Your Family Paediatrician</span>
    </a>

    <nav class="pill-nav" aria-label="Sections">
      {
        navLinks.map(({ label, href }) => (
          <a class="pill-link" href={href}>
            {label}
          </a>
        ))
      }
    </nav>

    <CallToAction href={bookingUrl} target="_blank" rel="noopener" size="small">
      Book a consultation
    </CallToAction>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgb(246 247 248 / 82%);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgb(31 58 52 / 7%);
  }

  .nav-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.8rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--text);
  }

  .wordmark {
    font-family: var(--font-brand);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
  }

  .pill-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2px;
    padding: 5px;
    background: var(--gray-999);
    border-radius: 999rem;
    box-shadow: 0 1px 2px rgb(31 58 52 / 6%);
  }

  .pill-link {
    padding: 0.5625rem 0.9375rem;
    border-radius: 999rem;
    font-family: var(--font-brand);
    font-weight: 600;
    font-size: 0.9063rem;
    color: #3a4a46;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--theme-transition);
  }

  .pill-link:hover,
  .pill-link:focus-visible {
    background-color: var(--aqua-tint);
  }
</style>
